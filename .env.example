APP_NAME="Citas Empresariales"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City
APP_URL=https://tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ============================================
# BASE DE DATOS - CPANEL NEUBOX TELLIT
# ============================================
# Configurar con credenciales de cPanel
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nombre_bd_cpanel
DB_USERNAME=usuario_cpanel
DB_PASSWORD=password_cpanel

# ============================================
# CACHE Y SESIONES
# ============================================
# Redis NO disponible en hosting compartido
# Usar database o file
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# ============================================
# EMAIL - SMTP PRODUCCIÓN
# ============================================
# Configuración para producción (cPanel)
MAIL_MAILER=smtp
MAIL_HOST=smtp.tudominio.com
MAIL_PORT=587
MAIL_USERNAME=noreply@tudominio.com
MAIL_PASSWORD=tu_password_smtp
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# Para desarrollo local con MailHog (Docker):
# MAIL_MAILER=smtp
# MAIL_HOST=mailhog
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null

# ============================================
# FILESYSTEM
# ============================================
FILESYSTEM_DISK=local

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=daily
LOG_STACK=single
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# ============================================
# SANCTUM (API móvil)
# ============================================
# IMPORTANTE: SESSION_DOMAIN debe coincidir exactamente con el dominio del servidor.
# Si el sitio es agendaya.mx, usar .agendaya.mx (con punto inicial).
# Si SESSION_DOMAIN no coincide, el cookie de sesión no se envía → error 419 CSRF.
# Dejar vacío (SESSION_DOMAIN=) para que solo aplique al dominio actual sin subdominios.
SANCTUM_STATEFUL_DOMAINS=agendaya.mx,www.agendaya.mx
SESSION_DOMAIN=.agendaya.mx

# ============================================
# VITE (Frontend assets)
# ============================================
VITE_APP_NAME="${APP_NAME}"
